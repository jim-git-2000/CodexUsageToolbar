#!/usr/bin/env python3
import argparse
import glob
import json
import os
import sqlite3
import sys
import time
from datetime import datetime
from decimal import Decimal


SCHEMA_VERSION = "1.0"
DEFAULT_WINDOWS = ("today", "1d", "7d", "14d", "30d")
CODEX_SESSIONS_GLOB = "~/.codex/sessions/**/*.jsonl"
FIVE_HOUR_MINUTES = 300
WEEKLY_MINUTES = 10080


def iso_from_epoch(ts):
    if ts is None:
        return None
    return datetime.fromtimestamp(int(ts)).astimezone().isoformat(timespec="seconds")


def now_iso():
    return datetime.now().astimezone().isoformat(timespec="seconds")


def parse_windows(raw, now_epoch):
    windows = []
    for item in raw.split(","):
        item = item.strip().lower()
        if not item:
            continue
        if item == "today":
            start = datetime.now().astimezone().replace(
                hour=0,
                minute=0,
                second=0,
                microsecond=0,
            )
            windows.append((item, int(start.timestamp())))
            continue
        if not item.endswith("d"):
            raise ValueError(f"unsupported window {item!r}; use today or Nd windows")
        days = int(item[:-1])
        if days <= 0:
            raise ValueError(f"window must be positive: {item!r}")
        windows.append((item, now_epoch - days * 86400))
    return windows


def decimal_to_float(value):
    return float(value.quantize(Decimal("0.000001")))


def connect_readonly(path):
    uri = f"file:{path}?mode=ro"
    return sqlite3.connect(uri, uri=True)


def table_exists(conn, name):
    row = conn.execute(
        "SELECT 1 FROM sqlite_master WHERE type='table' AND name=?",
        (name,),
    ).fetchone()
    return row is not None


def aggregate_window(conn, since_epoch):
    row = conn.execute(
        """
        SELECT
            COALESCE(SUM(input_tokens), 0),
            COALESCE(SUM(output_tokens), 0),
            COALESCE(SUM(cache_read_tokens), 0),
            COALESCE(SUM(cache_creation_tokens), 0),
            COALESCE(COUNT(*), 0),
            COALESCE(SUM(CAST(total_cost_usd AS REAL)), 0)
        FROM proxy_request_logs
        WHERE app_type = 'codex'
          AND created_at >= ?
        """,
        (since_epoch,),
    ).fetchone()

    input_tokens, output_tokens, cache_read_tokens, cache_creation_tokens, requests, total_cost = row
    input_tokens = int(input_tokens or 0)
    total_tokens = input_tokens + int(output_tokens or 0) + int(cache_creation_tokens or 0)
    hit_tokens = int(cache_read_tokens or 0)
    hit_rate = (hit_tokens / input_tokens) if input_tokens else 0.0

    return {
        "total_tokens": total_tokens,
        "hit_tokens": hit_tokens,
        "hit_rate": round(hit_rate, 6),
        "requests": int(requests or 0),
        "total_cost_usd": decimal_to_float(Decimal(str(total_cost or 0))),
    }


def get_last_event(conn):
    row = conn.execute(
        """
        SELECT MAX(created_at)
        FROM proxy_request_logs
        WHERE app_type = 'codex'
        """
    ).fetchone()
    return row[0] if row else None


def parse_event_timestamp(raw):
    if not raw:
        return 0
    try:
        return datetime.fromisoformat(raw.replace("Z", "+00:00")).timestamp()
    except Exception:
        return 0


def quota_unavailable():
    return {
        "remaining_percent": None,
        "used_percent": None,
        "reset_at": None,
        "available": False,
    }


def quota_from_rate_limit(item):
    if not item:
        return quota_unavailable()

    used = item.get("used_percent")
    reset_at = item.get("resets_at")
    if used is None or reset_at is None:
        return quota_unavailable()

    used = float(used)
    return {
        "remaining_percent": round(max(0.0, min(100.0, 100.0 - used)), 3),
        "used_percent": round(max(0.0, min(100.0, used)), 3),
        "reset_at": iso_from_epoch(reset_at),
        "available": True,
    }


def load_quota_from_codex_sessions():
    latest_by_window = {}
    for path in glob.glob(os.path.expanduser(CODEX_SESSIONS_GLOB), recursive=True):
        try:
            with open(path, "r", encoding="utf-8") as handle:
                for line in handle:
                    try:
                        event = json.loads(line)
                    except json.JSONDecodeError:
                        continue

                    rate_limits = (event.get("payload") or {}).get("rate_limits")
                    if not isinstance(rate_limits, dict):
                        continue

                    event_time = parse_event_timestamp(event.get("timestamp"))
                    for key in ("primary", "secondary"):
                        item = rate_limits.get(key)
                        if not isinstance(item, dict):
                            continue

                        window = item.get("window_minutes")
                        if window not in (FIVE_HOUR_MINUTES, WEEKLY_MINUTES):
                            continue

                        previous = latest_by_window.get(window)
                        if previous is None or event_time >= previous[0]:
                            latest_by_window[window] = (event_time, item)
        except OSError:
            continue

    return {
        "five_hour": quota_from_rate_limit(latest_by_window.get(FIVE_HOUR_MINUTES, (None, None))[1]),
        "weekly": quota_from_rate_limit(latest_by_window.get(WEEKLY_MINUTES, (None, None))[1]),
    }


def export_codex(args):
    db_path = os.path.expanduser(args.db)
    if not os.path.exists(db_path):
        raise FileNotFoundError(f"cc-switch database not found: {db_path}")

    now_epoch = int(time.time())
    windows = parse_windows(args.windows, now_epoch)
    collected_at = now_iso()

    with connect_readonly(db_path) as conn:
        if not table_exists(conn, "proxy_request_logs"):
            raise RuntimeError("cc-switch database does not contain proxy_request_logs")

        tokens = {
            label: aggregate_window(conn, since_epoch)
            for label, since_epoch in windows
        }
        last_event = get_last_event(conn)

    quota = load_quota_from_codex_sessions()
    errors = []
    if not quota["five_hour"]["available"] or not quota["weekly"]["available"]:
        errors.append(
            {
                "code": "QUOTA_PARTIAL",
                "message": "Some quota windows were not found in Codex session rate_limits.",
            }
        )

    return {
        "schema_version": SCHEMA_VERSION,
        "app": "codex",
        "source": "cc-switch-db-and-codex-session-exporter",
        "cc_switch": {
            "version": None,
        },
        "collected_at": collected_at,
        "quota": quota,
        "tokens": tokens,
        "refresh": {
            "last_success_at": collected_at,
            "cc_switch_last_event_at": iso_from_epoch(last_event),
            "stale": False,
        },
        "errors": errors,
    }


def build_parser():
    parser = argparse.ArgumentParser(
        prog="ccswitch-export",
        description="Export a stable, sanitized JSON contract for Codex usage from cc-switch.",
    )
    parser.add_argument("app", choices=["codex"])
    parser.add_argument("--windows", default=",".join(DEFAULT_WINDOWS))
    parser.add_argument("--json", action="store_true", dest="as_json")
    parser.add_argument("--db", default="~/.cc-switch/cc-switch.db")
    return parser


def main(argv):
    parser = build_parser()
    args = parser.parse_args(argv)

    try:
        payload = export_codex(args)
    except Exception as exc:
        print(f"ccswitch-export: {exc}", file=sys.stderr)
        return 1

    if not args.as_json:
        parser.error("only --json output is currently supported")

    print(json.dumps(payload, ensure_ascii=False, separators=(",", ":")))
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
